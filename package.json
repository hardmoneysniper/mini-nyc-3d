  "bugs": {
    "url": "https://github.com/hardmoneysniper/mini-nyc-3d/issues"
  },
  "homepage": "https://github.com/hardmoneysniper/mini-nyc-3d",
  "allowScripts": {
    "esbuild@0.14.7": true,
    "protobufjs@7.6.4": true,
    "core-js@3.49.0": true,
    "unrs-resolver@1.12.2": true,
    "vuepress@1.9.10": true,
    "highlight.js@9.18.5": true
  }
