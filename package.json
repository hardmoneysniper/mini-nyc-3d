{
  "name": "mini-nyc-3d",
  "version": "0.1.0",
  "description": "A real-time 3D digital map of New York City's public transport system",
  "main": "dist/mini-nyc-3d.js",
  "module": "dist/mini-nyc-3d.esm.js",
  "style": "dist/mini-nyc-3d.css",
  "dependencies": {
    "@deck.gl/core": "^8.9.36",
    "@deck.gl/geo-layers": "^8.9.36",
