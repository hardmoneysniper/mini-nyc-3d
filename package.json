  "devDependencies": {
    "@eslint/compat": "^2.0.1",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-image": "^3.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-strip": "^3.0.4",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/pluginutils": "^5.3.0",
    "eslint": "^9.39.2",
    "eslint-config-mourner": "^4.1.0",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsdoc": "^62.5.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "postcss-inline-svg": "^6.0.0",
    "rollup": "^4.57.1",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "vuepress": "^1.9.10",
    "vuepress-plugin-flexsearch": "^0.3.0"
  },
  "scripts": {
    "build": "rollup -c",
    "build-pages": "rm -rf build; cp -r public build; cp .npmignore dist/mini-nyc-3d.min.* build; mkdir -p build/assets; cp assets/dictionary-*.json assets/style.json build/assets; node -e \"const fs=require('fs'),t=process.env.MAPBOX_TOKEN||'';fs.writeFileSync('build/index.html',fs.readFileSync('build/index.html','utf8').replace('__MAPBOX_TOKEN__',t))\"",
    "fetch-gtfs": "node scripts/convert-mta-gtfs.js",
    "build-airways": "node scripts/build-airway-coords.js",
    "build-data": "rm -rf build/data; mkdir -p build/data; cp assets/dictionary-*.json assets/osm-liberty.json build/data; node dist/loader",
    "build-all": "run-s build build-pages build-data docs",
    "docs": "vuepress build docs --no-cache",
    "docs:dev": "vuepress dev docs --no-cache",
    "lint": "eslint --cache src"
  },
  "files": [
    "build/",
    "dist/mini-nyc-3d.*",
    "src/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hardmoneysniper/mini-nyc-3d.git"
  },
