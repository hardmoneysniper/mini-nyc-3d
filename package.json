    "mapbox-gl": "3.24.0",
    "mapbox-gl-animated-popup": "^0.4.0",
    "node.js": "^0.0.1-security",
    "pbf": "^4.0.1",
    "suncalc": "^1.9.0",
    "swiper": "^12.1.0",
    "three": "^0.182.0"
